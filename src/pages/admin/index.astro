---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
// Middleware has already verified authentication before this page renders.
---
<BaseLayout title="Adminpanel">
  <div class="admin-header">
    <h1>Adminpanel</h1>
    <a href="/admin/logout" class="logout-link">Logga ut</a>
  </div>

  <!-- ─── Stage 1: Upload & Transcribe ─────────────────────────────────── -->
  <section class="card" id="stage-upload">
    <h2>1. Ladda upp &amp; transkribera</h2>

    <!-- Transcription instructions -->
    <div class="field">
      <label for="transcribe-instructions">Transkriptionsinstruktioner</label>
      <textarea
        id="transcribe-instructions"
        rows="3"
      >Transkribera den handskrivna texten exakt. Ignorera och uteslut alla ord som är överstrukna. Slå ihop rader som hör till samma stycke till ett sammanhängande stycke — börja bara ett nytt stycke när det finns ett tydligt radbrytning eller ny mening i originaltexten. Bevara rubriker om sådana finns.</textarea>
    </div>

    <p class="hint">Ladda upp ett eller flera foton på handskriven text.</p>

    <div
      id="drop-zone"
      class="drop-zone"
      role="button"
      tabindex="0"
      aria-label="Klicka eller dra och släpp bilder för att ladda upp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="17 8 12 3 7 8"/>
        <line x1="12" y1="3" x2="12" y2="15"/>
      </svg>
      <p>Dra och släpp bilder här, eller <span class="browse-text">klicka för att bläddra</span></p>
      <p class="file-hint">JPEG, PNG, WebP eller GIF &mdash; max 20 MB vardera &mdash; flera filer tillåtna</p>
      <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/gif" multiple />
    </div>

    <div id="preview-container" class="preview-container hidden">
      <div id="preview-list" class="preview-list"></div>
      <button id="clear-image-btn" class="btn btn-ghost btn-sm" type="button">
        Ta bort alla bilder
      </button>
    </div>

    <div class="action-row">
      <button id="transcribe-btn" class="btn btn-primary" type="button" disabled>
        Transkribera med Claude
      </button>
      <span id="transcribe-status" class="status-text" aria-live="polite"></span>
    </div>
  </section>

  <!-- ─── Stage 2: Edit & Publish ──────────────────────────────────────── -->
  <section class="card" id="stage-content">
    <h2>2. Redigera &amp; publicera</h2>

    <div class="field">
      <label for="post-title">Titel <span class="required">*</span></label>
      <input type="text" id="post-title" placeholder="Min inläggsrubrik" autocomplete="off" />
    </div>

    <div class="field">
      <label for="post-slug">Slug <span class="required">*</span></label>
      <input type="text" id="post-slug" placeholder="mitt-inlagg" autocomplete="off" />
      <span class="field-hint">Autogenererad från titeln. URL: /posts/<em id="slug-preview">mitt-inlagg</em></span>
    </div>

    <div class="field">
      <label for="post-content">Innehåll <span class="required">*</span></label>
      <textarea
        id="post-content"
        rows="20"
        placeholder="Transkriberat eller manuellt skrivet innehåll visas här..."
      ></textarea>
    </div>

    <div class="action-row">
      <button id="publish-btn" class="btn btn-primary" type="button">
        Publicera inlägg
      </button>
      <span id="publish-status" class="status-text" aria-live="polite"></span>
    </div>
  </section>

  <!-- ─── Stage 3: Email Subscribers ──────────────────────────────────── -->
  <section class="card" id="stage-email" hidden>
    <h2>3. Meddela prenumeranter</h2>
    <p class="hint">Granska e-postmeddelandet nedan innan du skickar det till alla aktiva prenumeranter.</p>

    <div id="email-preview-box" class="email-preview">
      <div class="email-field">
        <span class="email-label">Ämne</span>
        <span id="email-subject"></span>
      </div>
      <div class="email-field">
        <span class="email-label">Inläggets URL</span>
        <a id="email-post-url" href="#" target="_blank" rel="noopener noreferrer"></a>
      </div>
      <div class="email-field">
        <span class="email-label">Innehåll</span>
        <span id="email-content-preview"></span>
      </div>
    </div>

    <p id="subscriber-info" class="hint"></p>

    <div class="action-row">
      <button id="send-email-btn" class="btn btn-primary" type="button">
        Skicka till prenumeranter
      </button>
      <button id="skip-email-btn" class="btn btn-ghost" type="button">
        Hoppa över (skicka inte)
      </button>
      <span id="email-status" class="status-text" aria-live="polite"></span>
    </div>

    <div id="done-message" class="done-message hidden">
      <p>Klart! Ditt inlägg är publicerat och prenumeranterna har meddelats.</p>
      <button id="new-post-btn" class="btn btn-primary" type="button">Starta ett nytt inlägg</button>
    </div>
  </section>
</BaseLayout>

<style>
  .admin-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  h1 {
    margin: 0;
    font-size: 1.6rem;
    font-weight: normal;
  }

  .logout-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
  }

  .logout-link:hover { color: var(--color-text); }

  .card {
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .card h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
    font-weight: 600;
    font-family: var(--font-sans);
  }

  .hint {
    margin: 0 0 1.25rem 0;
    font-size: 0.875rem;
    color: var(--color-muted);
    font-family: var(--font-sans);
  }

  /* Drop Zone */
  .drop-zone {
    border: 2px dashed var(--color-border);
    border-radius: 6px;
    padding: 2.5rem 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background-color 0.15s;
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }

  .drop-zone:hover,
  .drop-zone.drag-over {
    border-color: var(--color-accent);
    background-color: #f9f9f9;
  }

  .drop-zone svg { margin-bottom: 0.75rem; color: var(--color-muted); }
  .drop-zone p { margin: 0 0 0.25rem 0; }
  .file-hint { font-size: 0.8rem; color: #aaaaaa; }
  .browse-text { text-decoration: underline; color: var(--color-text); }
  .drop-zone input[type="file"] { display: none; }

  /* Image Preview */
  .preview-container {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .preview-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .preview-item {
    position: relative;
    cursor: grab;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-muted);
    width: 120px;
    max-width: 120px;
  }

  .preview-item:active { cursor: grabbing; }

  .preview-item.is-dragging { opacity: 0.4; }

  .preview-item.drag-over-item > img {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .preview-number {
    position: absolute;
    top: 4px;
    left: 4px;
    background: rgba(0, 0, 0, 0.65);
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    line-height: 1;
    padding: 3px 5px;
    border-radius: 3px;
    pointer-events: none;
    z-index: 1;
  }

  .preview-item img {
    width: 120px;
    height: 120px;
    max-width: 120px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .preview-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 120px;
  }

  /* Form Fields */
  .field { margin-bottom: 1.25rem; }

  label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }

  .required { color: #b91c1c; }

  .field-hint {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-top: 0.3rem;
  }

  input[type="text"],
  textarea {
    width: 100%;
    padding: 0.6rem 0.85rem;
    font-size: 0.95rem;
    font-family: var(--font-sans);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: #ffffff;
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s;
  }

  #post-content,
  #transcribe-instructions {
    font-family: 'Courier New', monospace;
    font-size: 0.875rem;
    resize: vertical;
    line-height: 1.6;
  }

  input[type="text"]:focus,
  textarea:focus { border-color: var(--color-accent); }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.15rem;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    border-radius: 4px;
    cursor: pointer;
    transition: opacity 0.15s;
    border: 1px solid transparent;
    font-weight: 500;
  }

  .btn-primary { background-color: var(--color-accent); color: #ffffff; border-color: var(--color-accent); }
  .btn-ghost { background-color: transparent; color: var(--color-text); border-color: var(--color-border); }
  .btn-sm { padding: 0.35rem 0.75rem; font-size: 0.8rem; }
  .btn:hover:not(:disabled) { opacity: 0.75; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* Action Row */
  .action-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.25rem;
    flex-wrap: wrap;
  }

  .status-text { font-family: var(--font-sans); font-size: 0.875rem; color: var(--color-muted); }
  .status-text.error { color: #b91c1c; }
  .status-text.success { color: #2d6a2d; }

  /* Email Preview */
  .email-preview {
    background: #f9f9f9;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 1.25rem;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .email-field {
    display: flex;
    gap: 1rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }

  .email-label {
    min-width: 70px;
    font-weight: 600;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  /* Done Message */
  .done-message {
    margin-top: 1.5rem;
    padding: 1.25rem;
    background: #f0faf0;
    border: 1px solid #a3d9a5;
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }

  .done-message p { margin: 0 0 1rem 0; color: #2d6a2d; }

  .hidden { display: none !important; }
</style>

<script>
  // ─── State ─────────────────────────────────────────────────────────────────
  let uploadedFiles: File[] = [];
  let publishedPostURL = '';
  let publishedPostTitle = '';
  let publishedPostContent = '';

  // ─── DOM References ────────────────────────────────────────────────────────
  const dropZone = document.getElementById('drop-zone') as HTMLDivElement;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const previewContainer = document.getElementById('preview-container') as HTMLDivElement;
  const previewList = document.getElementById('preview-list') as HTMLDivElement;
  const clearImageBtn = document.getElementById('clear-image-btn') as HTMLButtonElement;
  const transcribeBtn = document.getElementById('transcribe-btn') as HTMLButtonElement;
  const transcribeStatus = document.getElementById('transcribe-status') as HTMLSpanElement;
  const transcribeInstructions = document.getElementById('transcribe-instructions') as HTMLTextAreaElement;

  const postTitle = document.getElementById('post-title') as HTMLInputElement;
  const postSlug = document.getElementById('post-slug') as HTMLInputElement;
  const slugPreview = document.getElementById('slug-preview') as HTMLElement;
  const postContent = document.getElementById('post-content') as HTMLTextAreaElement;
  const publishBtn = document.getElementById('publish-btn') as HTMLButtonElement;
  const publishStatus = document.getElementById('publish-status') as HTMLSpanElement;

  const stageEmail = document.getElementById('stage-email') as HTMLElement;
  const emailSubject = document.getElementById('email-subject') as HTMLSpanElement;
  const emailPostUrl = document.getElementById('email-post-url') as HTMLAnchorElement;
  const emailContentPreview = document.getElementById('email-content-preview') as HTMLSpanElement;
  const subscriberInfo = document.getElementById('subscriber-info') as HTMLParagraphElement;
  const sendEmailBtn = document.getElementById('send-email-btn') as HTMLButtonElement;
  const skipEmailBtn = document.getElementById('skip-email-btn') as HTMLButtonElement;
  const emailStatus = document.getElementById('email-status') as HTMLSpanElement;
  const doneMessage = document.getElementById('done-message') as HTMLDivElement;
  const newPostBtn = document.getElementById('new-post-btn') as HTMLButtonElement;

  // ─── Helpers ───────────────────────────────────────────────────────────────
  function setStatus(el: HTMLSpanElement, text: string, type: 'idle' | 'error' | 'success' = 'idle') {
    el.textContent = text;
    el.className = `status-text${type !== 'idle' ? ' ' + type : ''}`;
  }

  function toSlug(s: string): string {
    return s
      .toLowerCase()
      .replace(/[^a-z0-9\s-]/g, '')
      .trim()
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-');
  }

  function renumberItems() {
    const items = previewList.querySelectorAll<HTMLDivElement>('.preview-item');
    items.forEach((item, idx) => {
      const badge = item.querySelector<HTMLSpanElement>('.preview-number');
      if (badge) badge.textContent = String(idx + 1);
    });
  }

  const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];

  // ─── File / Drop Zone ──────────────────────────────────────────────────────
  function handleFiles(files: FileList | File[]) {
    const arr = Array.from(files);
    const valid = arr.filter(f => {
      if (!ALLOWED_TYPES.includes(f.type)) {
        setStatus(transcribeStatus, `"${f.name}" är inte ett bildformat som stöds.`, 'error');
        return false;
      }
      if (f.size > 20 * 1024 * 1024) {
        setStatus(transcribeStatus, `"${f.name}" överstiger 20 MB.`, 'error');
        return false;
      }
      return true;
    });

    if (valid.length === 0) return;

    uploadedFiles = valid;

    // Build preview thumbnails
    previewList.innerHTML = '';
    valid.forEach((file, idx) => {
      const item = document.createElement('div');
      item.className = 'preview-item';
      item.draggable = true;
      (item as any)._file = file;

      const badge = document.createElement('span');
      badge.className = 'preview-number';
      badge.textContent = String(idx + 1);

      const img = document.createElement('img');
      img.src = URL.createObjectURL(file);
      img.alt = file.name;
      img.style.cssText = 'width:120px;height:120px;max-width:120px;object-fit:cover;border-radius:4px;border:1px solid #e0e0e0;display:block;flex-shrink:0;';

      const name = document.createElement('span');
      name.className = 'preview-name';
      name.textContent = file.name;

      item.appendChild(badge);
      item.appendChild(img);
      item.appendChild(name);
      previewList.appendChild(item);
    });

    previewContainer.classList.remove('hidden');
    transcribeBtn.disabled = false;
    setStatus(transcribeStatus, `${valid.length} bild${valid.length > 1 ? 'er' : ''} redo.`);
  }

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
  });
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    if (e.dataTransfer?.files.length) handleFiles(e.dataTransfer.files);
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) handleFiles(fileInput.files);
  });

  clearImageBtn.addEventListener('click', () => {
    uploadedFiles = [];
    previewList.innerHTML = '';
    previewContainer.classList.add('hidden');
    transcribeBtn.disabled = true;
    fileInput.value = '';
    setStatus(transcribeStatus, '');
  });

  // ─── Drag-to-reorder thumbnails ────────────────────────────────────────────
  let dragSrcItem: HTMLDivElement | null = null;

  previewList.addEventListener('dragstart', (e) => {
    const item = (e.target as HTMLElement).closest<HTMLDivElement>('.preview-item');
    if (!item) return;
    dragSrcItem = item;
    item.classList.add('is-dragging');
    e.dataTransfer!.effectAllowed = 'move';
  });

  previewList.addEventListener('dragend', () => {
    previewList.querySelectorAll('.preview-item').forEach(el => {
      el.classList.remove('is-dragging', 'drag-over-item');
    });
    dragSrcItem = null;
  });

  previewList.addEventListener('dragover', (e) => {
    e.preventDefault();
    e.dataTransfer!.dropEffect = 'move';
    const item = (e.target as HTMLElement).closest<HTMLDivElement>('.preview-item');
    if (!item || item === dragSrcItem) return;
    previewList.querySelectorAll('.preview-item').forEach(el => el.classList.remove('drag-over-item'));
    item.classList.add('drag-over-item');
  });

  previewList.addEventListener('dragleave', (e) => {
    const item = (e.target as HTMLElement).closest<HTMLDivElement>('.preview-item');
    if (item) item.classList.remove('drag-over-item');
  });

  previewList.addEventListener('drop', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest<HTMLDivElement>('.preview-item');
    if (!target || !dragSrcItem || target === dragSrcItem) return;

    const items = Array.from(previewList.children);
    const srcIdx = items.indexOf(dragSrcItem);
    const tgtIdx = items.indexOf(target);

    if (srcIdx < tgtIdx) {
      previewList.insertBefore(dragSrcItem, target.nextSibling);
    } else {
      previewList.insertBefore(dragSrcItem, target);
    }

    // Rebuild uploadedFiles to match new DOM order
    uploadedFiles = Array.from(previewList.querySelectorAll<HTMLDivElement>('.preview-item'))
      .map(el => (el as any)._file as File);

    renumberItems();
    previewList.querySelectorAll('.preview-item').forEach(el => el.classList.remove('drag-over-item'));
  });

  // ─── Auto-slug from title ──────────────────────────────────────────────────
  postTitle.addEventListener('input', () => {
    const slug = toSlug(postTitle.value);
    postSlug.value = slug;
    slugPreview.textContent = slug || 'mitt-inlagg';
  });

  postSlug.addEventListener('input', () => {
    slugPreview.textContent = postSlug.value || 'mitt-inlagg';
  });

  // ─── Transcribe (sequential, one image at a time) ─────────────────────────
  transcribeBtn.addEventListener('click', async () => {
    if (uploadedFiles.length === 0) return;

    transcribeBtn.disabled = true;
    const instructions = transcribeInstructions.value.trim() ||
      'Transkribera den handskrivna texten exakt. Ignorera och uteslut alla ord som är överstrukna. Slå ihop rader som hör till samma stycke till ett sammanhängande stycke — börja bara ett nytt stycke när det finns ett tydligt radbrytning eller ny mening i originaltexten. Bevara rubriker om sådana finns.';

    const results: string[] = [];

    for (let i = 0; i < uploadedFiles.length; i++) {
      const file = uploadedFiles[i];
      setStatus(
        transcribeStatus,
        uploadedFiles.length > 1
          ? `Transkriberar bild ${i + 1} av ${uploadedFiles.length}…`
          : 'Transkriberar… detta kan ta upp till 30 sekunder.'
      );

      const formData = new FormData();
      formData.append('image', file);
      formData.append('instructions', instructions);

      try {
        const res = await fetch('/api/transcribe', { method: 'POST', body: formData });
        const result = await res.json();

        if (res.ok && result.text) {
          results.push(result.text);
        } else {
          setStatus(transcribeStatus, `Bild ${i + 1}: ${result.error || 'Transkription misslyckades.'}`, 'error');
          transcribeBtn.disabled = false;
          return;
        }
      } catch {
        setStatus(transcribeStatus, `Nätverksfel för bild ${i + 1}. Försök igen.`, 'error');
        transcribeBtn.disabled = false;
        return;
      }
    }

    // Join all transcriptions with a separator between pages
    postContent.value = results.join('\n\n---\n\n');
    setStatus(
      transcribeStatus,
      results.length > 1
        ? `${results.length} bilder transkriberade. Granska och redigera innehållet nedan.`
        : 'Transkription klar. Redigera innehållet nedan.',
      'success'
    );
    transcribeBtn.disabled = false;
  });

  // ─── Publish ───────────────────────────────────────────────────────────────
  publishBtn.addEventListener('click', async () => {
    const title = postTitle.value.trim();
    const slug = postSlug.value.trim();
    const content = postContent.value.trim();

    if (!title || !slug || !content) {
      setStatus(publishStatus, 'Fyll i alla obligatoriska fält.', 'error');
      return;
    }

    publishBtn.disabled = true;
    setStatus(publishStatus, 'Publicerar till GitHub…');

    try {
      const res = await fetch('/api/publish', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, slug, content }),
      });
      const result = await res.json();

      if (res.ok) {
        publishedPostURL = result.url;
        publishedPostTitle = title;
        publishedPostContent = content;

        setStatus(
          publishStatus,
          `Publicerat! Ditt inlägg kommer att vara tillgängligt på ${result.url} när sajten byggs om (~2 min).`,
          'success'
        );

        stageEmail.hidden = false;
        stageEmail.scrollIntoView({ behavior: 'smooth', block: 'start' });

        emailSubject.textContent = `Things Written - ${title}`;
        emailPostUrl.textContent = result.url;
        emailPostUrl.href = result.url;
        const previewText = content.replace(/\s+/g, ' ').trim();
        emailContentPreview.textContent = previewText.length > 150
          ? previewText.slice(0, 150) + '…'
          : previewText;
        subscriberInfo.textContent = 'Utskicket meddelar alla aktiva prenumeranter med en länk till detta inlägg.';
      } else {
        setStatus(publishStatus, result.error || 'Publicering misslyckades. Försök igen.', 'error');
        publishBtn.disabled = false;
      }
    } catch {
      setStatus(publishStatus, 'Nätverksfel. Försök igen.', 'error');
      publishBtn.disabled = false;
    }
  });

  // ─── Send Email ────────────────────────────────────────────────────────────
  sendEmailBtn.addEventListener('click', async () => {
    if (!publishedPostURL) return;

    sendEmailBtn.disabled = true;
    skipEmailBtn.disabled = true;
    setStatus(emailStatus, 'Skickar…');

    try {
      const res = await fetch('/api/send-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ postTitle: publishedPostTitle, postURL: publishedPostURL, postContent: publishedPostContent }),
      });
      const result = await res.json();

      if (res.ok) {
        const msg = result.sent === 0
          ? 'Inga aktiva prenumeranter att meddela.'
          : `Skickat till ${result.sent} prenumerant${result.sent === 1 ? '' : 'er'}.`;
        setStatus(emailStatus, msg, 'success');
        doneMessage.classList.remove('hidden');
      } else {
        setStatus(emailStatus, result.error || 'Utskick misslyckades. Försök igen.', 'error');
        sendEmailBtn.disabled = false;
        skipEmailBtn.disabled = false;
      }
    } catch {
      setStatus(emailStatus, 'Nätverksfel. Försök igen.', 'error');
      sendEmailBtn.disabled = false;
      skipEmailBtn.disabled = false;
    }
  });

  skipEmailBtn.addEventListener('click', () => {
    setStatus(emailStatus, 'E-postutskick hoppades över.', 'idle');
    doneMessage.classList.remove('hidden');
  });

  // ─── Start a New Post ──────────────────────────────────────────────────────
  newPostBtn.addEventListener('click', () => {
    uploadedFiles = [];
    publishedPostURL = '';
    publishedPostTitle = '';
    publishedPostContent = '';

    previewList.innerHTML = '';
    previewContainer.classList.add('hidden');
    transcribeBtn.disabled = true;
    fileInput.value = '';

    postTitle.value = '';
    postSlug.value = '';
    slugPreview.textContent = 'mitt-inlagg';
    postContent.value = '';
    emailContentPreview.textContent = '';
    publishBtn.disabled = false;

    stageEmail.hidden = true;
    doneMessage.classList.add('hidden');
    sendEmailBtn.disabled = false;
    skipEmailBtn.disabled = false;

    [transcribeStatus, publishStatus, emailStatus].forEach(el => setStatus(el, ''));

    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
