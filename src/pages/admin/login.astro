---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createSessionCookie, SESSION_COOKIE_NAME } from '../../lib/auth';

let error = '';

// Handle POST: validate password and set session cookie
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const password = formData.get('password') as string;

  if (password === import.meta.env.ADMIN_PASSWORD) {
    const cookieValue = await createSessionCookie(import.meta.env.SESSION_SECRET);

    Astro.cookies.set(SESSION_COOKIE_NAME, cookieValue, {
      httpOnly: true,
      // Use PROD flag so local dev over HTTP still works
      secure: import.meta.env.PROD,
      sameSite: 'lax',
      path: '/',
      maxAge: 60 * 60 * 24, // 24 hours
    });

    return Astro.redirect('/admin');
  } else {
    error = 'Felaktigt lösenord.';
  }
}
---
<BaseLayout title="Adminpanel">
  <div class="login-wrapper">
    <h1>Adminpanel</h1>

    {error && (
      <p class="error-message" role="alert">{error}</p>
    )}

    <form method="POST" class="login-form">
      <label for="password">Lösenord</label>
      <input
        type="password"
        id="password"
        name="password"
        required
        autofocus
        autocomplete="current-password"
      />
      <button type="submit">Logga in</button>
    </form>
  </div>
</BaseLayout>

<style>
  .login-wrapper {
    max-width: 360px;
    margin: 3rem auto 0;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: normal;
    margin: 0 0 1.5rem 0;
  }

  .error-message {
    margin: 0 0 1rem 0;
    padding: 0.75rem 1rem;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 4px;
    color: #b91c1c;
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  input[type="password"] {
    padding: 0.65rem 0.9rem;
    font-size: 1rem;
    font-family: var(--font-sans);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }

  input[type="password"]:focus {
    border-color: var(--color-accent);
  }

  button[type="submit"] {
    padding: 0.65rem 1.25rem;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    background-color: var(--color-accent);
    color: #ffffff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: opacity 0.15s;
    align-self: flex-start;
  }

  button[type="submit"]:hover {
    opacity: 0.8;
  }
</style>
